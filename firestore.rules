rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'org_admin';
    }

    function isModuleLead() {
      return isSignedIn() && (
        getUserData().role == 'module_lead' ||
        getUserData().role == 'org_admin'
      );
    }

    // ── Users ──────────────────────────────────────────────────────
    // Any signed-in user can read all users (needed for admin screens & stats)
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Modules ────────────────────────────────────────────────────
    // All authenticated users can read modules (dashboard, dependency graph)
    match /modules/{moduleId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn(); // progress updates allowed for any member
      allow delete: if isAdmin();

      // Tasks subcollection — any signed-in user in the org can read/update
      match /tasks/{taskId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if isModuleLead();
      }
    }

    // ── Handshakes ─────────────────────────────────────────────────
    // Allow list for any authenticated user — app queries filter by moduleId
    // resource.data checks removed from list operations (Firestore limitation)
    match /handshakes/{handshakeId} {
      allow read: if isSignedIn();
      allow create: if isModuleLead();
      allow update: if isModuleLead();
      allow delete: if false; // Immutable — never delete
    }

    // ── Files ──────────────────────────────────────────────────────
    // Allow read for all authenticated users — app filters by moduleScope in query
    match /files/{fileId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false; // Immutable — no deletion

      match /versions/{versionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // ── Audit Log ──────────────────────────────────────────────────
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); // Written by app + Cloud Functions
      allow update, delete: if false; // Immutable — append-only
    }

    // ── Notifications ──────────────────────────────────────────────
    // Allow list for signed-in users — app queries filter by recipientId
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // mark as read
      allow delete: if false;
    }
  }
}
