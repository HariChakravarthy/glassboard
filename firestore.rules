rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userOrg() {
      return getUserData().orgId;
    }

    function isOrgUser(resourceData) {
      return resourceData.orgId == userOrg();
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'org_admin';
    }

    function isModuleLead() {
      return isSignedIn() && (
        getUserData().role == 'module_lead' ||
        getUserData().role == 'org_admin'
      );
    }

    // ── Organizations ──────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if true; // Public check needed for registering users using invite code
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() && resource.data.id == orgId;
    }

    // ── Users ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn() && (resource == null || resource.data.orgId == userOrg());
      allow create: if isOwner(uid);
      allow update: if (isOwner(uid) && (request.resource.data.orgId == resource.data.orgId)) || (isAdmin() && isOrgUser(resource.data));
      allow delete: if isAdmin() && isOrgUser(resource.data);
    }

    // ── Modules ────────────────────────────────────────────────────
    match /modules/{moduleId} {
      allow read: if isSignedIn() && isOrgUser(resource.data);
      allow create: if isAdmin() && request.resource.data.orgId == userOrg();
      allow update: if isSignedIn() && isOrgUser(resource.data) && request.resource.data.orgId == userOrg();
      allow delete: if isAdmin() && isOrgUser(resource.data);

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read: if isSignedIn() && isOrgUser(get(/databases/$(database)/documents/modules/$(moduleId)).data);
        allow create, update: if isSignedIn() && isOrgUser(get(/databases/$(database)/documents/modules/$(moduleId)).data);
        allow delete: if isModuleLead() && isOrgUser(get(/databases/$(database)/documents/modules/$(moduleId)).data);
      }
    }

    // ── Handshakes ─────────────────────────────────────────────────
    match /handshakes/{handshakeId} {
      allow read: if isSignedIn() && isOrgUser(resource.data);
      allow create: if isModuleLead() && request.resource.data.orgId == userOrg();
      allow update: if isModuleLead() && isOrgUser(resource.data) && request.resource.data.orgId == userOrg();
      allow delete: if false; // Immutable
    }

    // ── Files ──────────────────────────────────────────────────────
    match /files/{fileId} {
      allow read: if isSignedIn() && isOrgUser(resource.data);
      allow create: if isSignedIn() && request.resource.data.orgId == userOrg();
      allow update: if isSignedIn() && isOrgUser(resource.data) && request.resource.data.orgId == userOrg();
      allow delete: if false;

      match /versions/{versionId} {
        allow read: if isSignedIn() && isOrgUser(get(/databases/$(database)/documents/files/$(fileId)).data);
        allow create: if isSignedIn() && isOrgUser(get(/databases/$(database)/documents/files/$(fileId)).data);
        allow update, delete: if false;
      }
    }

    // ── Audit Log ──────────────────────────────────────────────────
    match /auditLog/{logId} {
      allow read: if isAdmin() && isOrgUser(resource.data);
      allow create: if isSignedIn() && request.resource.data.orgId == userOrg();
      allow update, delete: if false; // Immutable
    }

    // ── Notifications ──────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn() && isOwner(resource.data.recipientId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isOwner(resource.data.recipientId);
      allow delete: if false;
    }
  }
}
